{
  "tests": [
    {
      "name": "Список мастеров",
      "method": "GET",
      "path": "/?action=masters",
      "expectedStatus": 200,
      "bodyMatcher": "none"
    },
    {
      "name": "POST confirm_email_change — неверный код",
      "method": "POST",
      "path": "/",
      "body": {"action": "confirm_email_change", "master_id": 999999, "new_email": "test@example.com", "code": "000000"},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Неверный или устаревший код"}
    },
    {
      "name": "POST confirm_phone_change — неверный код",
      "method": "POST",
      "path": "/",
      "body": {"action": "confirm_phone_change", "master_id": 999999, "new_phone": "+79001234567", "code": "000000"},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Неверный или устаревший код"}
    }
  ]
}