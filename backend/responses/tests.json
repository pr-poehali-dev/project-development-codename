{
  "tests": [
    {
      "name": "POST create response — без master_id должен вернуть 403",
      "method": "POST",
      "path": "/",
      "body": {
        "order_id": 1,
        "master_name": "Тест Мастер",
        "master_phone": "+79001234567",
        "master_category": "Сантехника",
        "message": "Тестовый отклик"
      },
      "expectedStatus": 403,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходимо войти в кабинет мастера"}
    },
    {
      "name": "GET responded order ids for master",
      "method": "GET",
      "path": "/?master_id=999999",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"responded_order_ids": []}
    }
  ]
}
